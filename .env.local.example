# Local development environment
# Copy to .env.local and fill with your own values.
# Never commit .env.local.

# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=servija
DB_PASSWORD=servija_local_dev_password
DB_NAME=servija

# JWT
JWT_SECRET=change-me-local-dev-secret
JWT_EXPIRES_IN=7d

# Email (optional)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
